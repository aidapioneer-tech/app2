# --- APP SETTINGS ---
# The public URL of the application host (e.g., https://app.aidapioneer.by)
NUXT_PUBLIC_SITE_URL=https://app.aidapioneer.by

# Base path under which this app is deployed (see AGENTS.md "NUXT_APP_BASE_URL" rule).
# Pattern: /<purpose-slug>-<entropy>. Use the same value here, in the Bitrix24 app
# installation URL and on the CDN deploy path.
NUXT_APP_BASE_URL=/money-info-a4f7

# --- SECURITY ---
# Comma-separated list of allowed hosts for Vite dev server (e.g., "example.com,foo.com")
NUXT_ALLOWED_HOSTS=
